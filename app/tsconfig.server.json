{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/tsconfig.server.tsbuildinfo"
  },
  "include": ["server/**/*.ts"]
}
