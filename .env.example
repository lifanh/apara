# Required: path to the APARA knowledge repo
APARA_REPO_PATH=/path/to/knowledge-repo

# Optional: set to enable auth (required for non-localhost access)
# When set, server binds to 0.0.0.0 instead of 127.0.0.1
APARA_AUTH_TOKEN=

# Optional: restrict CORS to a specific origin (default: same-origin only)
APARA_ALLOWED_ORIGIN=

# Required: LLM provider API key (used by Pi Agent SDK)
# Set the key for whichever provider your model uses:
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Optional: server port (default: 3000)
# PORT=3000

# Optional: override the listen host. Default is 127.0.0.1 when auth is
# disabled, 0.0.0.0 when APARA_AUTH_TOKEN is set. The Docker image sets
# this to 0.0.0.0 so the container is reachable via port-forwarding.
# APARA_BIND_HOST=0.0.0.0

# Optional: set to "1" when running behind a trusted reverse proxy
# (e.g. Caddy, nginx, Cloudflare). Allows the rate limiter to read the
# real client IP from the last entry of the X-Forwarded-For header
# instead of trusting the direct TCP peer. Do NOT enable when the server
# is exposed directly to the internet — the header is client-spoofable.
# APARA_TRUST_PROXY=1
